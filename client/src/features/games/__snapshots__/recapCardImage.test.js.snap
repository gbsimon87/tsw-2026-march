// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`recapCardImage > creates a broadcast-style SVG recap card 1`] = `
"<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="958" viewBox="0 0 1080 958" role="img" aria-label="Game recap card">
    <defs>
      <linearGradient id="cardBg" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#0f172a" />
        <stop offset="45%" stop-color="#111827" />
        <stop offset="100%" stop-color="#1e293b" />
      </linearGradient>
      <linearGradient id="heroAccent" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#f59e0b" stop-opacity="0.9" />
        <stop offset="55%" stop-color="#f97316" stop-opacity="0.34" />
        <stop offset="100%" stop-color="#22d3ee" stop-opacity="0.22" />
      </linearGradient>
      <linearGradient id="performerAccent" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#fbbf24" />
        <stop offset="100%" stop-color="#f59e0b" />
      </linearGradient>
    </defs>

    <rect width="1080" height="958" rx="48" fill="url(#cardBg)" />
    <rect x="32" y="32" width="1016" height="894" rx="42" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="2" />
    <circle cx="1010" cy="86" r="132" fill="rgba(255,255,255,0.05)" />
    <rect x="-20" y="778" width="220" height="110" rx="30" transform="rotate(-18 90 833)" fill="rgba(255,255,255,0.05)" />
    <rect x="0" y="0" width="1080" height="958" fill="url(#heroAccent)" />
    <line x1="0" y1="670" x2="1080" y2="670" stroke="rgba(255,255,255,0.08)" />
    <line x1="716" y1="90" x2="716" y2="646" stroke="rgba(255,255,255,0.08)" />

    <text x="56" y="78" font-size="14" font-weight="900" fill="#fbbf24" letter-spacing="6">GAME RECAP</text>
    <rect x="56" y="92" width="152" height="112" rx="26" fill="rgba(255,255,255,0.92)" />
    <image href="https://example.com/team-logo.png" x="76" y="92" width="112" height="112" preserveAspectRatio="xMidYMid slice" />

    <text x="236" y="128" font-size="56" font-weight="900" fill="#f8fafc">TSW Blue</text>
    <text x="236" y="170" font-size="20" font-weight="700" fill="#94a3b8" letter-spacing="3">Final</text>
    <text x="236" y="204" font-size="24" font-weight="600" fill="#cbd5e1">Mar 12, 2026</text>

    <rect x="56" y="244" width="968" height="230" rx="30" fill="rgba(2,6,23,0.32)" stroke="rgba(255,255,255,0.08)" />
    
    <text x="418" y="330" font-size="24" font-weight="800" fill="#f8fafc" letter-spacing="2">TSW Blue</text>
    <text x="970" y="332" text-anchor="end" font-size="88" font-weight="900" fill="#ffffff">70</text>
  
    
    <text x="418" y="430" font-size="24" font-weight="800" fill="#cbd5e1" letter-spacing="2">Falcons</text>
    <text x="970" y="432" text-anchor="end" font-size="88" font-weight="900" fill="#e2e8f0">61</text>
  
    <text x="418" y="292" font-size="14" font-weight="900" fill="#fbbf24" letter-spacing="4">SCOREBOARD</text>

    <rect x="56" y="504" width="968" height="120" rx="24" fill="rgba(2,6,23,0.28)" stroke="rgba(255,255,255,0.08)" />
    <text x="86" y="548" font-size="16" font-weight="900" fill="#fbbf24" letter-spacing="4">GAME NOTE</text>
    <text x="86" y="590" font-size="30" font-weight="700" fill="#f8fafc">Jordan Miles led the way with 24 PTS.</text>

    <rect x="56" y="652" width="280" height="86" rx="22" fill="rgba(2,6,23,0.26)" stroke="rgba(255,255,255,0.08)" />
    <rect x="360" y="652" width="280" height="86" rx="22" fill="rgba(2,6,23,0.26)" stroke="rgba(255,255,255,0.08)" />
    <rect x="664" y="652" width="360" height="86" rx="22" fill="rgba(2,6,23,0.26)" stroke="rgba(255,255,255,0.08)" />
    <text x="84" y="684" font-size="13" font-weight="900" fill="#94a3b8" letter-spacing="3">POINTS</text>
    <text x="84" y="718" font-size="34" font-weight="900" fill="#f8fafc">70</text>
    <text x="388" y="684" font-size="13" font-weight="900" fill="#94a3b8" letter-spacing="3">REB • AST</text>
    <text x="388" y="718" font-size="34" font-weight="900" fill="#f8fafc">10 • 12</text>
    <text x="692" y="684" font-size="13" font-weight="900" fill="#94a3b8" letter-spacing="3">FG2% • FG3% • FT%</text>
    <text x="692" y="718" font-size="30" font-weight="900" fill="#f8fafc">50% • 40% • 75%</text>

    <text x="56" y="744" font-size="16" font-weight="900" fill="#fbbf24" letter-spacing="4">TOP PERFORMERS</text>
    
      <rect x="56" y="770" width="968" height="92" rx="22" fill="rgba(2,6,23,0.34)" stroke="rgba(255,255,255,0.08)" />
      <rect x="74" y="784" width="64" height="64" rx="18" fill="url(#performerAccent)" />
      <text x="106" y="825" text-anchor="middle" font-size="22" font-weight="900" fill="#0f172a">JM</text>
      <text x="160" y="808" font-size="28" font-weight="800" fill="#f8fafc">Jordan Miles</text>
      <text x="160" y="836" font-size="18" font-weight="600" fill="#cbd5e1">24 PTS • 8 REB • 5 AST</text>
      <text x="970" y="826" text-anchor="end" font-size="13" font-weight="800" fill="#fbbf24" letter-spacing="2">TOP PERFORMER</text>
    
  </svg>"
`;
