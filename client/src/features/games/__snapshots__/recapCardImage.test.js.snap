// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`recapCardImage > creates a broadcast-style SVG recap card 1`] = `
"<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="616" viewBox="0 0 1080 616" role="img" aria-label="Game recap card">
  <defs></defs>

  <!-- Background -->
  <rect width="1080" height="616" rx="40" fill="white" />
  <rect x="1" y="1" width="1078" height="614" rx="40" fill="none" stroke="#e2e8f0" stroke-width="2" />

  <!-- Header -->
  <circle cx="64" cy="48" r="28" fill="#f59e0b" /><text x="64" y="56" text-anchor="middle" font-size="20" font-weight="900" fill="white" font-family="system-ui,sans-serif">TB</text>
  <text x="108" y="40" font-size="11" font-weight="900" fill="#94a3b8" letter-spacing="5" font-family="system-ui,sans-serif">GAME RECAP</text>
  <text x="108" y="64" font-size="18" font-weight="700" fill="#475569" font-family="system-ui,sans-serif">Mar 12, 2026</text>
  <line x1="40" y1="96" x2="1040" y2="96" stroke="#f1f5f9" stroke-width="2" />

  <!-- Score section -->
  <rect x="40" y="112" width="1000" height="270" rx="24" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />

  <!-- Status badge -->
  <rect x="480" y="124" width="120" height="28" rx="14" fill="#e2e8f0" />
  <text x="540" y="143" text-anchor="middle" font-size="11" font-weight="900" fill="#475569" letter-spacing="3" font-family="system-ui,sans-serif">FINAL</text>

  <!-- Home row -->
  
      <circle cx="92" cy="196" r="32" fill="#f59e0b" /><text x="92" y="206" text-anchor="middle" font-size="23" font-weight="900" fill="white" font-family="system-ui,sans-serif">TB</text>
      <text x="140" y="207" font-size="30" font-weight="800" fill="#0f172a" font-family="system-ui,sans-serif">TSW Blue</text>
      <text x="1040" y="224" text-anchor="end" font-size="80" font-weight="900" fill="#0f172a" font-family="system-ui,sans-serif">70</text>
    

  <!-- Separator -->
  <line x1="56" y1="261" x2="1024" y2="261" stroke="#e2e8f0" stroke-width="1" />

  <!-- Away row -->
  
      <circle cx="92" cy="326" r="32" fill="#64748b" /><text x="92" y="336" text-anchor="middle" font-size="23" font-weight="900" fill="white" font-family="system-ui,sans-serif">F</text>
      <text x="140" y="337" font-size="30" font-weight="800" fill="#94a3b8" font-family="system-ui,sans-serif">Falcons</text>
      <text x="1040" y="354" text-anchor="end" font-size="80" font-weight="900" fill="#cbd5e1" font-family="system-ui,sans-serif">61</text>
    

  <!-- Top performers section -->
  <text x="40" y="430" font-size="11" font-weight="900" fill="#94a3b8" letter-spacing="5" font-family="system-ui,sans-serif">TOP PERFORMERS</text>

  
    <rect x="40" y="456" width="1000" height="88" rx="18" fill="#f8fafc" stroke="#e2e8f0" stroke-width="1" />
    <circle cx="84" cy="500" r="28" fill="#f59e0b" />
    <text x="84" y="508" text-anchor="middle" font-size="16" font-weight="900" fill="white" font-family="system-ui,sans-serif">JM</text>
    <text x="124" y="490" font-size="22" font-weight="800" fill="#0f172a" font-family="system-ui,sans-serif">Jordan Miles</text>
    
    <text x="124" y="516" font-size="16" font-weight="700" fill="#64748b" font-family="system-ui,sans-serif">24 PTS · 8 REB · 5 AST</text>
  
</svg>"
`;
