// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`recapCardImage > creates a header-style SVG recap card 1`] = `
"<svg xmlns="http://www.w3.org/2000/svg" width="1080" height="420" viewBox="0 0 1080 420" role="img" aria-label="Game recap card">
  <defs></defs>

  <rect width="1080" height="420" rx="40" fill="white" />
  <rect x="1" y="1" width="1078" height="418" rx="40" fill="none" stroke="#e2e8f0" stroke-width="2" />

  
  <text x="64" y="78" font-size="18" font-weight="800" fill="#94a3b8" letter-spacing="2" font-family="system-ui,sans-serif">Final</text>
  <text x="1016" y="78" text-anchor="end" font-size="18" font-weight="600" fill="#94a3b8" font-family="system-ui,sans-serif">Mar 12, 2026</text>
  <line x1="64" y1="126" x2="1016" y2="126" stroke="#e2e8f0" stroke-width="2" />

  
      <circle cx="98" cy="190" r="38" fill="#f59e0b" /><text x="98" y="201" text-anchor="middle" font-size="27" font-weight="900" fill="white" font-family="system-ui,sans-serif">TB</text>
      <text x="160" y="202" font-size="34" font-weight="800" fill="#0f172a" font-family="system-ui,sans-serif">TSW Blue</text>
      <text x="960" y="220" text-anchor="end" font-size="86" font-weight="900" fill="#0f172a" font-family="system-ui,sans-serif">70</text>
    

  <line x1="64" y1="250" x2="1016" y2="250" stroke="#e2e8f0" stroke-width="1" />

  
      <circle cx="98" cy="310" r="38" fill="#64748b" /><text x="98" y="321" text-anchor="middle" font-size="27" font-weight="900" fill="white" font-family="system-ui,sans-serif">F</text>
      <text x="160" y="322" font-size="34" font-weight="800" fill="#94a3b8" font-family="system-ui,sans-serif">Falcons</text>
      <text x="960" y="340" text-anchor="end" font-size="86" font-weight="900" fill="#cbd5e1" font-family="system-ui,sans-serif">61</text>
    
</svg>"
`;
