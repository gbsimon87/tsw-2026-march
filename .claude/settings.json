  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"$f\" in */env/*|*.env|*.env.*|*/render.yaml) echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Editing env files, .env, or render.yaml is blocked by policy (see docs/security.md). Secrets are managed by hand / via the Render dashboard, never through file edits.\"}}';; esac",
            "statusMessage": "Checking secret-file policy"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "m=$(jq -r '.tool_input.command' | perl -ne 'if (/-m\\s+\"([^\"]*)\"/) {print \"$1\";exit} elsif (/-m\\s+'\\''([^'\\'']*)'\\''/) {print \"$1\";exit}'); [ -z \"$m\" ] && exit 0; printf '%s' \"$m\" | ./node_modules/.bin/commitlint --config commitlint.config.cjs",
            "statusMessage": "Linting commit message"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // .tool_response.filePath // empty'); case \"$f\" in */client/*|*/server/*) case \"$f\" in *.js|*.jsx|*.cjs|*.mjs) ./node_modules/.bin/prettier --write \"$f\" >/dev/null 2>&1; ./node_modules/.bin/eslint --fix \"$f\" >/dev/null 2>&1;; esac;; esac; exit 0",
            "statusMessage": "Formatting + lint-fixing"
          },
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // .tool_response.filePath // empty'); case \"$f\" in */server/src/config/env.js|*/client/src/lib/env.js|*/render.yaml) pnpm check-env 2>&1 | tail -20 || true;; esac; exit 0",
            "statusMessage": "Validating env contract"
          }
        ]
      }
    ]
  },
